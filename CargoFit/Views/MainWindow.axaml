<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CargoFit.MainWindow"
        Title="CargoFit"
        Width="1100"
        Height="700"
        MinWidth="800"
        MinHeight="560"
        WindowState="Maximized"
        Background="#F1F5F9">
  <DockPanel>

    <!-- Top bar -->
    <Border DockPanel.Dock="Top"
            Height="52"
            Background="White"
            BorderThickness="0,0,0,1"
            BorderBrush="#1E293B">
      <Grid ColumnDefinitions="*,Auto,*" Margin="16,0">

        <TextBlock Grid.Column="1"
                   Text="CargoFit"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#1E293B" />

        <Button x:Name="SettingsButton"
                Grid.Column="2"
                Content="Settings"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Padding="16,6"
                Click="OpenSettings_Click" />
      </Grid>
    </Border>

    <!-- Trial-expiry banner (visible when ≤3 days remain) -->
    <Border x:Name="TrialBanner"
            DockPanel.Dock="Top"
            Background="#FEF3C7"
            BorderBrush="#F59E0B"
            BorderThickness="0,0,0,1"
            Padding="16,8"
            IsVisible="False">
      <TextBlock x:Name="TrialBannerText"
                 FontSize="13"
                 FontWeight="Medium"
                 Foreground="#92400E"
                 HorizontalAlignment="Center" />
    </Border>

    <!-- Update-available banner (visible when a new GitHub release is found) -->
    <Border x:Name="UpdateBanner"
            DockPanel.Dock="Top"
            Background="#EFF6FF"
            BorderBrush="#3B82F6"
            BorderThickness="0,0,0,1"
            Padding="16,6"
            IsVisible="False">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock x:Name="UpdateBannerText"
                   Grid.Column="0"
                   FontSize="13"
                   FontWeight="Medium"
                   Foreground="#1E40AF"
                   VerticalAlignment="Center" />
        <Button x:Name="UpdateButton"
                Grid.Column="1"
                Classes="primary"
                Content="อัปเดตเดี๋ยวนี้"
                Click="UpdateButton_Click" />
      </Grid>
    </Border>

    <!-- Single-page planning view -->
    <ContentControl x:Name="MainContent" />

  </DockPanel>
</Window>
