<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="logistic.SettingsWindow"
             Background="#F1F5F9">
  <Grid ColumnDefinitions="200,Auto,*">

    <!-- Sidebar -->
    <Border Grid.Column="0"
            Background="White"
            BorderThickness="0,0,1,0"
            BorderBrush="#E2E8F0">
      <StackPanel Margin="12,16">
        <TextBlock Text="SETTINGS"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="#94A3B8"
                   Margin="8,0,0,8" />
        <ListBox x:Name="SidebarList"
                 SelectionChanged="SidebarList_SelectionChanged"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.ItemContainerTheme>
            <ControlTheme TargetType="ListBoxItem">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="Padding" Value="10,8"/>
              <Setter Property="CornerRadius" Value="6"/>
              <Setter Property="Foreground" Value="#374151"/>
              <Setter Property="FontSize" Value="14"/>
              <Setter Property="Cursor" Value="Hand"/>
              <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="#F1F5F9"/>
              </Style>
              <Style Selector="^:selected /template/ ContentPresenter">
                <Setter Property="Background" Value="#EFF6FF"/>
                <Setter Property="TextElement.Foreground" Value="#2563EB"/>
                <Setter Property="FontWeight" Value="Medium"/>
              </Style>
            </ControlTheme>
          </ListBox.ItemContainerTheme>
          <ListBoxItem Content="Container" Tag="Container" />
          <ListBoxItem Content="สินค้า" Tag="Product" />
        </ListBox>
      </StackPanel>
    </Border>

    <!-- Divider -->
    <Border Grid.Column="1" Width="1" Background="#E2E8F0" />

    <!-- Content area -->
    <ContentControl Grid.Column="2"
                    x:Name="ContentArea" />

  </Grid>
</UserControl>
